{
  "name": "mcp-multimodal",
  "version": "1.0.1",
  "description": "MCP server for multimodal generation: MiniMax (TTS/Image/Video/Music) + MiMo (TTS)",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "multimodal-mcp": "dist/server.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsc && node dist/server.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "multimodal",
    "minimax",
    "mimo",
    "tts",
    "text-to-speech",
    "image-generation",
    "video-generation",
    "music-generation",
    "xiaomi"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/liaoxinjie666/multimodal-mcp.git"
  },
  "homepage": "https://github.com/liaoxinjie666/multimodal-mcp#readme",
  "bugs": {
    "url": "https://github.com/liaoxinjie666/multimodal-mcp/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "jszip": "^3.10.1",
    "pdfjs-dist": "^4.4.168",
    "zod": "^3.24.0"
  },
  "optionalDependencies": {
    "ffmpeg-static": "^5.3.0"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "@types/node": "^22.0.0"
  }
}
